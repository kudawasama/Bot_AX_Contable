#!/bin/sh
#
# pre-commit hook — auto-bump según los archivos modificados.
#
# Examina los archivos staged (git diff --cached) y decide:
#   - Archivos nuevos añadidos → minor (+0.01.00)
#   - Archivos eliminados → minor (+0.01.00)
#   - Solo modificaciones en archivos existentes → patch (+0.00.01)
#   - Si se tocó _version.py manualmente → NO bump (el usuario decidió)
#
# Se activa con: git config core.hooksPath .githooks

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
[ -f "$REPO_ROOT/_version.py" ] || exit 0
cd "$REPO_ROOT" || exit 0

# Si el usuario modificó _version.py manualmente, no auto-bumpear
if git diff --cached --name-only 2>/dev/null | grep -q "^_version.py$"; then
    git add _version.py 2>/dev/null || true
    exit 0
fi

# Detectar tipo de bump según los cambios
ADDED=$(git diff --cached --diff-filter=A --name-only 2>/dev/null | wc -l)
DELETED=$(git diff --cached --diff-filter=D --name-only 2>/dev/null | wc -l)

if [ "$ADDED" -gt 0 ] || [ "$DELETED" -gt 0 ]; then
    python bump_version.py minor 2>/dev/null || true
else
    python bump_version.py patch 2>/dev/null || true
fi

git add _version.py 2>/dev/null || true
