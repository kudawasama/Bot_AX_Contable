#!/bin/sh
#
# pre-commit hook — auto-bump según los archivos modificados.
#
# Examina los archivos staged (git diff --cached) y decide:
#   - _version.py tocado manualmente → NO bump (el usuario decidió)
#   - Archivos NUEVOS añadidos → minor (+0.01.00)
#   - Archivos ELIMINADOS → minor (+0.01.00)
#   - Solo modificaciones en archivos existentes → patch (+0.00.01)
#
# Se activa con: git config core.hooksPath .githooks

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$REPO_ROOT" || exit 0

# Buscar version.py en src/core/
VPY=""
[ -f "src/core/version.py" ] && VPY="src/core/version.py"
[ -z "$VPY" ] && exit 0

# Si el usuario tocó version.py manualmente, no auto-bumpear
if git diff --cached --name-only 2>/dev/null | grep -q "$VPY"; then
    git add "$VPY" 2>/dev/null || true
    exit 0
fi

# Detectar tipo de bump según los cambios
ADDED=$(git diff --cached --diff-filter=A --name-only 2>/dev/null | grep -c . || true)
DELETED=$(git diff --cached --diff-filter=D --name-only 2>/dev/null | grep -c . || true)

if [ "$ADDED" -gt 0 ] || [ "$DELETED" -gt 0 ]; then
    python scripts/bump_version.py minor 2>/dev/null || true
else
    python scripts/bump_version.py patch 2>/dev/null || true
fi

git add "$VPY" 2>/dev/null || true
