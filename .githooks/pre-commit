#!/bin/sh
#
# pre-commit hook — auto-bump patch version en cada commit.
# Solo incrementa patch (+0.00.01). Sin errores, sin lógica extra.
#
# Se activa con: git config core.hooksPath .githooks

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
[ -f "$REPO_ROOT/_version.py" ] || exit 0
cd "$REPO_ROOT" || exit 0

python bump_version.py patch 2>/dev/null || true
git add _version.py 2>/dev/null || true
